# 与「`/root/.hydro` + PM2 caddy」生产配置对齐的示例：
# - Hydro 主体：8888
# - 自定义网关 hydro-api（domainUsers 等）：8890
# - /api/run：示例 3999
#
# 同步接口已改为 **`/extras/sync/*`**（见 `docs/SYNC-CADDY-ROUTING.md`），勿再依赖 `/api/sync/*`。
#
oj.antmaker.vip {
  encode zstd gzip
  log {
    output file /data/access.log {
      roll_size 1gb
      roll_keep_for 72h
    }
    format json
  }
  root * /root/.hydro/static

  @gateway {
    path /api/* /login /logout
  }
  handle_path /api/run {
    reverse_proxy http://127.0.0.1:3999
  }

  handle @gateway {
    reverse_proxy http://127.0.0.1:8890
  }

  @static {
    file {
      try_files {path}
    }
  }
  handle @static {
    file_server
  }
  handle {
    reverse_proxy http://127.0.0.1:8888
  }
}
